{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "endOfLine": "lf",
    "ignorePatterns": ["template/**"],
    "printWidth": 100,
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",

    "overrides": [
        {
            "files": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
