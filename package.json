{
    "name": "@duonghieu0712z/create-tauri-vue-template",
    "version": "0.0.12",
    "description": "Create a Tauri 2 + Vue 3 desktop app from the tauri-vue-template starter.",
    "repository": {
        "type": "git",
        "url": "https://github.com/duonghieu0712z/create-tauri-vue-template"
    },
    "bin": {
        "create-tauri-vue-template": "dist/bin/index.js"
    },
    "files": [
        "dist",
        "template"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
        "build": "pnpm clean && tsc -p tsconfig.json",
        "format": "oxfmt --check .",
        "format:fix": "oxfmt .",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "prepack": "pnpm build"
    },
    "dependencies": {
        "cac": "^7.0.0",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "typescript": "~6.0.3"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
